# ──────────────────────────────────────────────
# HZ Bingo — Backend Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/bingo_db

# JWT
JWT_SECRET=your-secret-key-min-32-chars
JWT_EXPIRES_IN=7d

# Server
NODE_ENV=development
PORT=5000

# CORS
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Supabase (optional — only required if using Supabase auth/storage)
SUPABASE_URL=
SUPABASE_KEY=

# Twilio (optional — only required for SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# TypeORM
SYNCHRONIZE=false
