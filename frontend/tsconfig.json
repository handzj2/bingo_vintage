{
  "_comment": "build-fix 2026-06-15: exclude backend files so Vercel does not try to compile typeorm/data-source",
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "forceConsistentCasingInFileNames": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "data-source.ts",
    "database/**",
    "dist/**",
    "test/**",
    "src/app.module.ts",
    "src/main.ts",
    "src/common/**/*",
    "src/modules/**/*",
    "src/services/clientFormAdapter.ts",
    "src/services/clientListAdapter.ts",
    "src/services/clientNormalizer.ts",
    "database/**/*"
  ]
}
